  code          = "/**\n * Segment Destination Function to sync Engage Audiences & Journeys to Vero\n * Sends audience states directly as explicit true/false booleans.\n * * @param {SegmentTrackEvent} event - Incoming Segment Track event\n * @param {Object} settings - Configuration settings\n */\nasync function onTrack(event, settings) {\n\tconst context = event.context || {};\n\tconst personas = context.personas || {};\n\tconst traits = context.traits || {};\n\n\t// 1. Guard Clause: Ensure this is a Persona/Engage event\n\tif (\n\t\t!personas.computation_id &&\n\t\t!personas.audience_key &&\n\t\t!personas.journey_name\n\t) {\n\t\tconsole.log(\n\t\t\t'Skipping event: Not generated by Segment Engage Audiences or Journeys.'\n\t\t);\n\t\treturn;\n\t}\n\n\t// 2. Extract user identifiers\n\tconst userId = event.userId;\n\tif (!userId) {\n\t\tthrow new ValidationError('User ID is required to sync to Vero.');\n\t}\n\n\tlet email = event.email || traits.email;\n\n\t// FALLBACK: Fetch email from Segment Profile API if missing from payload\n\tif (!email) {\n\t\tconsole.log(\n\t\t\t`Email missing from payload for user $${userId}. Fetching from Segment Profile API...`\n\t\t);\n\n\t\tif (!settings.segmentSpaceId || !settings.segmentAccessToken) {\n\t\t\tconsole.log(\n\t\t\t\t'Warning: Segment Profile API settings missing. Proceeding without email fetch.'\n\t\t\t);\n\t\t} else {\n\t\t\tconst profileUrl = `https://profiles.segment.com/v1/spaces/$${settings.segmentSpaceId}/users/id:$${userId}/traits`;\n\t\t\tconst encodedToken = btoa(`$${settings.segmentAccessToken}:`);\n\n\t\t\ttry {\n\t\t\t\tconst profileResponse = await fetch(profileUrl, {\n\t\t\t\t\tmethod: 'GET',\n\t\t\t\t\theaders: {\n\t\t\t\t\t\tAuthorization: `Basic $${encodedToken}`,\n\t\t\t\t\t\t'Content-Type': 'application/json'\n\t\t\t\t\t}\n\t\t\t\t});\n\n\t\t\t\tif (profileResponse.ok) {\n\t\t\t\t\tconst profileData = await profileResponse.json();\n\t\t\t\t\tif (\n\t\t\t\t\t\tprofileData.traits &&\n\t\t\t\t\t\t(profileData.traits.email || profileData.traits.Email)\n\t\t\t\t\t) {\n\t\t\t\t\t\temail = profileData.traits.email || profileData.traits.Email;\n\t\t\t\t\t\tconsole.log(\n\t\t\t\t\t\t\t`Successfully retrieved email from Profile API for user $${userId}.`\n\t\t\t\t\t\t);\n\t\t\t\t\t} else {\n\t\t\t\t\t\tconsole.log(\n\t\t\t\t\t\t\t`Profile API returned traits for $${userId}, but no email field was found.`\n\t\t\t\t\t\t);\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\tconsole.log(\n\t\t\t\t\t\t`Segment Profile API request failed with status: $${profileResponse.status}`\n\t\t\t\t\t);\n\t\t\t\t}\n\t\t\t} catch (err) {\n\t\t\t\tconsole.error(`Error querying Segment Profile API: $${err.message}`);\n\t\t\t}\n\t\t}\n\t}\n\n\t// 3. Determine the Audience Key & Dynamic Boolean Status (true/false)\n\tlet audienceKey = '';\n\tlet audienceStatus = false; // Default baseline state\n\n\tconst eventName = event.event || '';\n\tif (eventName.toLowerCase().includes('entered')) {\n\t\taudienceStatus = true; // Resolves to JSON boolean: true\n\t} else if (eventName.toLowerCase().includes('exited')) {\n\t\taudienceStatus = false; // Resolves to JSON boolean: false\n\t}\n\n\tif (personas.audience_key) {\n\t\taudienceKey = personas.audience_key;\n\t} else if (personas.journey_name) {\n\t\tconst traitsKeys = Object.keys(traits);\n\t\taudienceKey =\n\t\t\ttraitsKeys.find(\n\t\t\t\tkey => key !== 'email' && typeof traits[key] === 'boolean'\n\t\t\t) || `journey_$${personas.journey_name}`;\n\t} else {\n\t\taudienceKey = `persona_computation_$${personas.computation_id}`;\n\t}\n\n\tconst cleanAudienceKey = audienceKey\n\t\t.toLowerCase()\n\t\t.replace(/[^a-z0-9_]/g, '_');\n\n\t// 4. Construct the Vero Track API Payload\n\tconst veroPayload = {\n\t\tauth_token: settings.authToken,\n\t\tidentity: {\n\t\t\tid: userId\n\t\t},\n\t\tdata: {\n\t\t\t[cleanAudienceKey]: audienceStatus // Pushes native JSON true or false\n\t\t}\n\t};\n\n\tif (email) {\n\t\tveroPayload.identity.email = email;\n\t}\n\n\t// 5. Fire request to Vero's Track API\n\tconst url = 'https://api.getvero.com/api/v2/users/track';\n\tlet response;\n\n\ttry {\n\t\tresponse = await fetch(url, {\n\t\t\tmethod: 'POST',\n\t\t\theaders: {\n\t\t\t\t'Content-Type': 'application/json'\n\t\t\t},\n\t\t\tbody: JSON.stringify(veroPayload)\n\t\t});\n\t} catch (error) {\n\t\tthrow new RetryError(`Network connection failed: $${error.message}`);\n\t}\n\n\t// 6. Handle HTTP Response Rules\n\tif (response.status === 429 || response.status >= 500) {\n\t\tthrow new RetryError(\n\t\t\t`Temporary error from Vero. Status Code: $${response.status}`\n\t\t);\n\t}\n\n\tif (response.status >= 400 && response.status < 500) {\n\t\tconst errorText = await response.text();\n\t\tthrow new ValidationError(\n\t\t\t`Vero rejected payload ($${response.status}): $${errorText}`\n\t\t);\n\t}\n\n\tconsole.log(\n\t\t`Successfully synced state to Vero. Property: '$${cleanAudienceKey}' | State: $${audienceStatus} | User: $${userId}`\n\t);\n}\n\n/**\n * Handle identify event\n * @param  {SegmentIdentifyEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onIdentify(event, settings) {\n\t// Learn more at https://segment.com/docs/connections/spec/identify/\n\tthrow new EventNotSupported('identify is not supported');\n}\n\n/**\n * Handle group event\n * @param  {SegmentGroupEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onGroup(event, settings) {\n\t// Learn more at https://segment.com/docs/connections/spec/group/\n\tthrow new EventNotSupported('group is not supported');\n}\n\n/**\n * Handle page event\n * @param  {SegmentPageEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onPage(event, settings) {\n\t// Learn more at https://segment.com/docs/connections/spec/page/\n\tthrow new EventNotSupported('page is not supported');\n}\n\n/**\n * Handle screen event\n * @param  {SegmentScreenEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onScreen(event, settings) {\n\t// Learn more at https://segment.com/docs/connections/spec/screen/\n\tthrow new EventNotSupported('screen is not supported');\n}\n\n/**\n * Handle alias event\n * @param  {SegmentAliasEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onAlias(event, settings) {\n\t// Learn more at https://segment.com/docs/connections/spec/alias/\n\tthrow new EventNotSupported('alias is not supported');\n}\n\n/**\n * Handle delete event\n * @param  {SegmentDeleteEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onDelete(event, settings) {\n\t// Learn more at https://segment.com/docs/partners/spec/#delete\n\tthrow new EventNotSupported('delete is not supported');\n}\n"
