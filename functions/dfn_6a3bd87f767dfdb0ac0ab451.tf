resource "segment_function" "id-dfn_6a3bd87f767dfdb0ac0ab451" {
  code          = "/**\n * Segment Destination Function to sync Engage Audiences & Journeys to Vero\n * Sends audience states directly as explicit true/false booleans.\n * @param {SegmentTrackEvent} event - Incoming Segment Track event\n * @param {Object} settings - Configuration settings\n */\nasync function onTrack(event, settings) {\n\tconst context = event.context || {};\n\tconst personas = context.personas || {};\n\tconst traits = context.traits || {};\n\n\t// Extract properties and journey metadata from the event payload\n\tconst properties = event.properties || {};\n\tconst journeyMetadata = properties.journey_metadata || {};\n\tconsole.log(journeyMetadata);\n\n\t// 1. Guard Clause: Ensure this is an Engage Audience or Journey event\n\tif (\n\t\t!personas.computation_id ||\n\t\t!personas.audience_key ||\n\t\t!personas.journey_name ||\n\t\t!journeyMetadata.journey_step_name\n\t) {\n\t\tconsole.log(\n\t\t\t'Skipping event: Not generated by Segment Engage Audiences or Journeys.'\n\t\t);\n\t\treturn;\n\t}\n\n\t// 2. Extract user identifiers\n\tconst userId = event.userId;\n\tif (!userId) {\n\t\tthrow new ValidationError('User ID is required to sync to Vero.');\n\t}\n\n\tlet email = event.email || properties.email || traits.email;\n\n\t// 3. Determine the Audience Key & Dynamic Boolean Status (true/false)\n\tlet audienceStatus = false; // Default baseline state\n\n\tconst eventName = event.event || '';\n\tif (eventName.toLowerCase().includes('entered')) {\n\t\taudienceStatus = true;\n\t} else if (eventName.toLowerCase().includes('exited')) {\n\t\taudienceStatus = false;\n\t} else {\n\t\t// Fallback: If event name doesn't contain entered/exited, assume true (step reached)\n\t\taudienceStatus = true;\n\t}\n\n\t// --- Updated Audience Key Generation ---\n\tlet audienceKey = '';\n\tif (personas.audience_key) {\n\t\taudienceKey = personas.audience_key;\n\t} else if (journeyMetadata.journey_step_id) {\n\t\t// Concatenate Journey Step Name & Journey Name\n\t\tconst journeyName =\n\t\t\tjourneyMetadata.journey_name ||\n\t\t\tpersonas.journey_name ||\n\t\t\t'unknown_journey';\n\t\taudienceKey = `$${journeyMetadata.journey_step_id}_$${journeyName}`;\n\t\tconsole.log('true journey name condition', audienceKey);\n\t} else {\n\t\taudienceKey = `persona_computation_$${personas.computation_id}`;\n\t}\n\tconsole.log('Audience Key Matrix:', audienceKey);\n\tconst cleanAudienceKey = audienceKey\n\t\t.toLowerCase()\n\t\t.replace(/[^a-z0-9_]/g, '_');\n\n\t// 4. Construct the Vero API Payload (Fixed Hierarchy)\n\tconst veroPayload = {\n\t\tauth_token: settings.veroAuthToken,\n\t\tid: userId,\n\t\tdata: {\n\t\t\t[cleanAudienceKey]: audienceStatus\n\t\t}\n\t};\n\n\tif (email) {\n\t\tveroPayload.email = email;\n\t}\n\n\tconsole.log(veroPayload);\n\t// 5. Fire request back to Vero's Users Track API\n\tconst url = 'https://api.getvero.com/api/v2/users/track';\n\tlet response;\n\n\ttry {\n\t\tresponse = await fetch(url, {\n\t\t\tmethod: 'POST',\n\t\t\theaders: {\n\t\t\t\t'Content-Type': 'application/json'\n\t\t\t},\n\t\t\tbody: JSON.stringify(veroPayload)\n\t\t});\n\t} catch (error) {\n\t\tthrow new RetryError(`Network connection failed: $${error.message}`);\n\t}\n\n\t// 6. Handle HTTP Response Rules\n\tif (response.status === 429 || response.status >= 500) {\n\t\tthrow new RetryError(\n\t\t\t`Temporary error from Vero. Status Code: $${response.status}`\n\t\t);\n\t}\n\n\tif (response.status >= 400 && response.status < 500) {\n\t\tconst errorText = await response.text();\n\t\tthrow new ValidationError(\n\t\t\t`Vero rejected payload ($${response.status}): $${errorText}`\n\t\t);\n\t}\n\n\tconsole.log(\n\t\t`Successfully synced state to Vero. Property: '$${cleanAudienceKey}' | State: $${audienceStatus} | User: $${userId}`\n\t);\n}\n"
