resource "segment_function" "id-dfn_6a3bd87f767dfdb0ac0ab451" {
  code          = "/**\n * Segment Destination Function to sync Engage Audiences & Journeys to Vero\n * Sends audience states directly as explicit true/false booleans via Identify events.\n * @param {SegmentIdentifyEvent} event - Incoming Segment Identify event\n * @param {Object} settings - Configuration settings\n */\nasync function onIdentify(event, settings) {\n\tconst context = event.context || {};\n\tconst personas = context.personas || {};\n\n\t// Engage traits live at root event.traits for identify, fallback to context\n\tconst traits = event.traits || context.traits || {};\n\n\t// 1. Guard Clause: Ensure this is a Persona/Engage event\n\tif (\n\t\t!personas.computation_id &&\n\t\t!personas.audience_key &&\n\t\t!personas.journey_name\n\t) {\n\t\tconsole.log(\n\t\t\t'Skipping event: Not generated by Segment Engage Audiences or Journeys.'\n\t\t);\n\t\treturn;\n\t}\n\n\t// 2. Extract user identifiers\n\tconst userId = event.userId;\n\tif (!userId) {\n\t\tthrow new ValidationError('User ID is required to sync to Vero.');\n\t}\n\n\tlet email = event.email || traits.email || traits.Email;\n\n\t// 3. Determine the Audience Key & Extract Direct Boolean Status (true/false)\n\tlet audienceKey = '';\n\tif (personas.audience_key) {\n\t\taudienceKey = personas.audience_key;\n\t} else if (personas.journey_name) {\n\t\tconst traitsKeys = Object.keys(traits);\n\t\taudienceKey =\n\t\t\ttraitsKeys.find(\n\t\t\t\tkey => key.toLowerCase() !== 'email' && typeof traits[key] === 'boolean'\n\t\t\t) || `journey_$${personas.journey_name}`;\n\t} else {\n\t\taudienceKey = `persona_computation_$${personas.computation_id}`;\n\t}\n\n\tconst cleanAudienceKey = audienceKey\n\t\t.toLowerCase()\n\t\t.replace(/[^a-z0-9_]/g, '_');\n\n\t// Pull the native boolean status directly out of the traits payload\n\tlet audienceStatus = false;\n\n\tif (traits[audienceKey] !== undefined) {\n\t\taudienceStatus =\n\t\t\ttraits[audienceKey] === true || traits[audienceKey] === 'true';\n\t} else if (traits[cleanAudienceKey] !== undefined) {\n\t\taudienceStatus =\n\t\t\ttraits[cleanAudienceKey] === true || traits[cleanAudienceKey] === 'true';\n\t} else {\n\t\t// Dynamic Fallback: Look for any remaining boolean value in traits that isn't the email field\n\t\tconst fallbackKey = Object.keys(traits).find(\n\t\t\tkey => key.toLowerCase() !== 'email' && typeof traits[key] === 'boolean'\n\t\t);\n\t\tif (fallbackKey) {\n\t\t\taudienceStatus = traits[fallbackKey] === true;\n\t\t}\n\t}\n\n\t// 4. Construct the Vero Track API Payload (Flat structure for Users Track API)\n\tconst veroPayload = {\n\t\tauth_token: settings.veroAuthToken,\n\t\tid: userId, // Moved to root level\n\t\tdata: {\n\t\t\t[cleanAudienceKey]: audienceStatus\n\t\t}\n\t};\n\n\tif (email) {\n\t\tveroPayload.email = email; // Moved to root level\n\t}\n\n\t// 5. Fire request to Vero's Track API\n\tconst url = 'https://api.getvero.com/api/v2/users/track';\n\tlet response;\n\tconsole.log(veroPayload);\n\ttry {\n\t\tresponse = await fetch(url, {\n\t\t\tmethod: 'POST',\n\t\t\theaders: {\n\t\t\t\t'Content-Type': 'application/json'\n\t\t\t},\n\t\t\tbody: JSON.stringify(veroPayload)\n\t\t});\n\t} catch (error) {\n\t\tthrow new RetryError(`Network connection failed: $${error.message}`);\n\t}\n\n\t// 6. Handle HTTP Response Rules\n\tif (response.status === 429 || response.status >= 500) {\n\t\tthrow new RetryError(\n\t\t\t`Temporary error from Vero. Status Code: $${response.status}`\n\t\t);\n\t}\n\n\tif (response.status >= 400 && response.status < 500) {\n\t\tconst errorText = await response.text();\n\t\tthrow new ValidationError(\n\t\t\t`Vero rejected payload ($${response.status}): $${errorText}`\n\t\t);\n\t}\n\n\tconsole.log(\n\t\t`Successfully synced state to Vero via Identify. Property: '$${cleanAudienceKey}' | State: $${audienceStatus} | User: $${userId}`\n\t);\n}\n\n/**\n * Handle track event\n * @param  {SegmentTrackEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onTrack(event, settings) {\n\tthrow new EventNotSupported('track is not supported');\n}\n\n/**\n * Handle group event\n * @param  {SegmentGroupEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onGroup(event, settings) {\n\tthrow new EventNotSupported('group is not supported');\n}\n\n/**\n * Handle page event\n * @param  {SegmentPageEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onPage(event, settings) {\n\tthrow new EventNotSupported('page is not supported');\n}\n\n/**\n * Handle screen event\n * @param  {SegmentScreenEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onScreen(event, settings) {\n\tthrow new EventNotSupported('screen is not supported');\n}\n\n/**\n * Handle alias event\n * @param  {SegmentAliasEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onAlias(event, settings) {\n\tthrow new EventNotSupported('alias is not supported');\n}\n\n/**\n * Handle delete event\n * @param  {SegmentDeleteEvent} event\n * @param  {FunctionSettings} settings\n */\nasync function onDelete(event, settings) {\n\tthrow new EventNotSupported('delete is not supported');\n}\n"
