  code          = "/**\n * Segment Destination Function to sync Engage Journeys to Vero\n * Configured specifically for journey_step events sent to the Vero Events API.\n */\nasync function processJourneyStep(event, settings) {\n\tconst context = event.context || {};\n\tconst personas = context.personas || {};\n\n\tconst computationClass =\n\t\tcontext.computation_class || personas.computation_class;\n\n\t// 1. Guard Clause: ONLY execute if computation_class is exactly 'journey_step'\n\tif (computationClass !== 'journey_step') {\n\t\tconsole.log(\n\t\t\t`Skipping event: computation_class is '$${computationClass}', not 'journey_step'.`\n\t\t);\n\t\treturn;\n\t}\n\n\t// 2. Extract user identifiers\n\tconst userId = event.userId;\n\tif (!userId) {\n\t\tthrow new ValidationError('User ID is required to sync to Vero.');\n\t}\n\n\tconst properties = event.properties || {};\n\tconst traits = event.traits || context.traits || {};\n\tconst email =\n\t\tevent.email ||\n\t\tproperties.email ||\n\t\ttraits.email ||\n\t\tproperties.Email ||\n\t\ttraits.Email;\n\n\t// 3. Extract Journey Name as Event Name & Computation Key as Event Property Key\n\tconst journeyMetadata = properties.journey_metadata || {};\n\tconst journeyName = journeyMetadata.journey_name;\n\n\tif (!journeyName) {\n\t\tthrow new ValidationError(\n\t\t\t'Journey name is missing from properties.journey_metadata.journey_name'\n\t\t);\n\t}\n\n\tconst computationKey = personas.computation_key;\n\tif (!computationKey) {\n\t\tthrow new ValidationError(\n\t\t\t'Computation key is missing from context.personas.computation_key'\n\t\t);\n\t}\n\n\t// Clean strings for safe API compliance (lowercase, alphanumeric, underscores)\n\tconst cleanEventName = journeyName.toLowerCase().replace(/[^a-z0-9_]/g, '_');\n\tconst cleanPropertyKey = computationKey\n\t\t.toLowerCase()\n\t\t.replace(/[^a-z0-9_]/g, '_');\n\n\t// 4. Construct Vero Events API Payload (Property value is inherently true)\n\tconst veroPayload = {\n\t\tauth_token: settings.veroAuthToken,\n\t\tidentity: {\n\t\t\tid: userId\n\t\t},\n\t\tevent_name: cleanEventName,\n\t\tdata: {\n\t\t\t[cleanPropertyKey]: true\n\t\t}\n\t};\n\n\tif (email) {\n\t\tveroPayload.identity.email = email;\n\t}\n\n\t// 5. Fire request to Vero's Events API\n\tconst url = 'https://api.getvero.com/api/v2/events/track';\n\tlet response;\n\n\ttry {\n\t\tresponse = await fetch(url, {\n\t\t\tmethod: 'POST',\n\t\t\theaders: {\n\t\t\t\t'Content-Type': 'application/json'\n\t\t\t},\n\t\t\tbody: JSON.stringify(veroPayload)\n\t\t});\n\t} catch (error) {\n\t\tthrow new RetryError(`Network connection failed: $${error.message}`);\n\t}\n\n\t// 6. Handle HTTP Response Rules\n\tif (response.status === 429 || response.status >= 500) {\n\t\tthrow new RetryError(\n\t\t\t`Temporary error from Vero. Status Code: $${response.status}`\n\t\t);\n\t}\n\n\tif (response.status >= 400 && response.status < 500) {\n\t\tconst errorText = await response.text();\n\t\tthrow new ValidationError(\n\t\t\t`Vero rejected payload ($${response.status}): $${errorText}`\n\t\t);\n\t}\n\n\tconsole.log(\n\t\t`Successfully tracked journey step to Vero. Event: '$${cleanEventName}' | Property: '$${cleanPropertyKey}': true`\n\t);\n}\n\n/**\n * Handle Track and Identify events\n */\nasync function onTrack(event, settings) {\n\tawait processJourneyStep(event, settings);\n}\n\nasync function onIdentify(event, settings) {\n\tawait processJourneyStep(event, settings);\n}\n\n/**\n * Unused handlers\n */\nasync function onGroup(event, settings) {\n\tthrow new EventNotSupported('group is not supported');\n}\nasync function onPage(event, settings) {\n\tthrow new EventNotSupported('page is not supported');\n}\nasync function onScreen(event, settings) {\n\tthrow new EventNotSupported('screen is not supported');\n}\nasync function onAlias(event, settings) {\n\tthrow new EventNotSupported('alias is not supported');\n}\nasync function onDelete(event, settings) {\n\tthrow new EventNotSupported('delete is not supported');\n}\n"
